{
  "name": "swades-ai",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "db:generate": "pnpm --filter @swades-ai/db db:generate",
    "db:migrate": "pnpm --filter @swades-ai/db db:migrate",
    "db:seed": "pnpm --filter @swades-ai/db db:seed"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "turbo": "^2.5.3",
    "typescript": "~6.0.2"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  }
}
